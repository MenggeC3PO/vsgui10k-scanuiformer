{
  
  "trials_path": "data/trials_official_with_validation.jsonl.gz",
  "image_dir": "data/vsgui10k-images",
  "seg_root": "data/segmentation",

  "target_present_only": true,
  "seed": 42,
  "train_ratio": 0.8,
  "val_ratio": 0.1,
  "test_ratio": 0.1,

  "image_size": 224,
  "target_crop_size": 64,
  "crop_size": 64,
  "history_len": 8,
  "max_scanpath_len": 20,
  "max_ui_tokens": 96,

  "vit_name": "vit_tiny_patch16_224",
  "pretrained": true,
  "freeze_patch_backbone": true,
  "use_patch_memory": false,
  "use_ui_memory": true,
  "use_ui_crops": true,
  "use_ui_type": true,
  "use_ui_geom": true,
  "use_ui_target_similarity": true,
  "use_candidate_stop": true,
  "use_target_aware_stop": false,

  "ui_memory_scale": 1.0,
  "ui_geom_dim": 10,
  "d_model": 256,
  "nhead": 8,
  "num_layers": 3,
  "ui_num_layers": 2,
  "patch_num_layers": 1,
  "state_refine_layers": 2,
  "ff_dim": 1024,
  "dropout": 0.12,
  "max_delta": 1.0,

  "duration_target": "log1p",
  "duration_scale": 1.0,
  "duration_output": "softplus",
  "duration_feature_clip": 8.0,

  "batch_size": 4,
  "num_workers": 0,
  "lr": 1e-5,
  "weight_decay": 0.0001,
  "grad_clip": 1.0,

  "init_checkpoint": null,
  "resume": null,

  "rollout_teacher_forcing_ratio": 0.45,

  "coord_loss_weight": 1.0,
  "stop_loss_weight": 0.035,
  "stop_pos_weight_cap": 3.0,
  "duration_loss_weight": 0.2,
  "delta_loss_weight": 1.2,
  "step_len_loss_weight": 0.9,
  "direction_loss_weight": 0.4,
  "stop_far_loss_weight": 0.2,
  "revisit_loss_weight": 0.3,
  "revisit_radius": 0.08,
  "revisit_recent_k": 8,
  "anti_reversal_loss_weight": 0.15,
  "candidate_loss_weight": 0.4,
  "found_loss_weight": 0.05,
  "candidate_target_tau": 0.06,

  "target_stop_margin": 0.05,
  "train_min_stop_step": 3,
  "min_stop_step": 4,

  "save_best_by": "val_loss",
  "eval_thresholds": [0.25, 0.3, 0.35, 0.4, 0.45, 0.5, 0.55, 0.6],
  "eval_margins": [0.0, 0.03, 0.05, 0.1],

  "experiment_name": "train_scanuiformer_from_scratch",
  "output_dir": "outputs/train_scanuiformer_from_scratch",

  "max_train_samples": null,
  "max_val_samples": null,
  "max_test_samples": null,
  "epochs": 120,

  "seekui_test_ids_path": "configs/seekui_test_ids.txt",
  "force_seekui_test_as_test": true,
  "include_random_test_with_seekui_holdout": false,

  "target_cue_filter": null,
  "detach_rollout_history": true,
  "duration_loss": "smooth_l1",
  "found_target_mode": "stop_label",
  "coord_loss": "smooth_l1",
  "smooth_l1_beta": 0.05,
  "strict_finite_check": true,
  "print_every_batches": 10,
  "seekui_holdout_enabled": true,
  "target_type_filter": null
}
